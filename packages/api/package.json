{
  "name": "@repo/api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc --watch --preserveWatchOutput",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/types": "workspace:*"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts",
    "./client": "./src/client.ts",
    "./fetcher": "./src/fetcher.ts",
    "./services": "./src/services.ts",
    "./routes/base-api": "./src/routes/base-api.ts",
    "./routes/data-sim": "./src/routes/data-sim.ts",
    "./routes/evm": "./src/routes/evm.ts",
    "./routes/new-visa": "./src/routes/new-visa.ts",
    "./routes/qr-visa": "./src/routes/qr-visa.ts",
    "./routes/review-visa": "./src/routes/review-visa.ts",
    "./routes/track-visa-application": "./src/routes/track-visa-application.ts",
    "./routes/visa-payment-summary": "./src/routes/visa-payment-summary.ts"
  },
  "prettier": "@repo/prettier-config"
}
