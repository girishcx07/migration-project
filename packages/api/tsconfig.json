{
  "extends": "@repo/tsconfig/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "noEmitOnError": true,
    "stripInternal": true,
    "composite": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@repo/types*": ["../types/src*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
