{
  "name": "@repo/b2b",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 env-cmd -f .env.uat vite build --configLoader native",
    "build:uat": "cross-env NODE_OPTIONS=--max-old-space-size=4096 env-cmd -f .env.uat vite build --configLoader native",
    "build:prod": "cross-env NODE_OPTIONS=--max-old-space-size=4096 env-cmd -f .env.prod vite build --configLoader native",
    "dev": "cross-env NODE_ENV=development env-cmd -f .env.uat vite --configLoader native",
    "dev:uat": "cross-env NODE_ENV=development env-cmd -f .env.uat vite --configLoader native",
    "dev:prod": "cross-env NODE_ENV=development env-cmd -f .env.prod vite --configLoader native",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "format:fix": "prettier --write . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "lint:fix": "eslint --flag unstable_native_nodejs_ts_config --fix",
    "start": "cross-env NODE_ENV=production node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remix-run/node-fetch-server": "catalog:",
    "@repo/api": "workspace:*",
    "@repo/portal": "workspace:*",
    "@repo/rsc-action-requests": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "compression": "catalog:",
    "cross-env": "catalog:",
    "express": "catalog:",
    "motion": "catalog:",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-router": "catalog:",
    "sonner": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/compression": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "@vitejs/plugin-rsc": "catalog:",
    "env-cmd": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-devtools-json": "catalog:"
  },
  "prettier": "@repo/prettier-config"
}
